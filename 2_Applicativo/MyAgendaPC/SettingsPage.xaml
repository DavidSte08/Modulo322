                    <!-- Icona a sinistra -->
                    <Image Source="access-icon.png" 
                   WidthRequest="24" 
                   HeightRequest="24" 
                   VerticalOptions="Center" />

                    <!-- Testo Centrale -->
                    <Label Grid.Column="1" 
                   Text="Accesso e Password" 
                   VerticalOptions="Center" 
                   Margin="15,0"
                   FontSize="16"
