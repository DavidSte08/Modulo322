                   Opacity="0.5"
                   VerticalOptions="Center" />

                    <!-- Gesture Recognizer per il click -->
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToTimeZoneCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>

                <!-- Separatore -->
                <BoxView HeightRequest="1" Color="#EEEEEE" Margin="15,0" />

                <!-- Fuso Orario (template di Google AI)-->
                <Grid Style="{StaticResource MenuRowStyle}" ColumnDefinitions="Auto, *, Auto">
                    <!-- Icona a sinistra -->
                    <Image Source="clock-icon.png" 
                   WidthRequest="24" 
                   HeightRequest="24" 
                   VerticalOptions="Center" />

                    <!-- Testo Centrale -->
                    <Label Grid.Column="1" 
                   Text="Fuso orario" 
                   VerticalOptions="Center" 
                   Margin="15,0"
                   FontSize="16"
                   TextColor="Black" />

                    <!-- Freccia a destra -->
                    <Image Grid.Column="2" 
                   Source="chevron_right.png" 
                   WidthRequest="12" 
                   Opacity="0.5"
                   VerticalOptions="Center" />

                    <!-- Gesture Recognizer per il click -->
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToTimeZoneCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>

                <!-- Separatore -->
                <BoxView HeightRequest="1" Color="#EEEEEE" Margin="15,0" />

                <!-- Widget -->
                <Grid Style="{StaticResource MenuRowStyle}" ColumnDefinitions="Auto, *, Auto">
                    <!-- Icona a sinistra -->
                    <Image Source="widgets-icon.png" 
                   WidthRequest="24" 
                   HeightRequest="24" 
                   VerticalOptions="Center" />

                    <!-- Testo Centrale -->
