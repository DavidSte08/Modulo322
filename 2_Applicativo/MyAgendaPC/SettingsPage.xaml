                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToTimeZoneCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>

                <!-- Separatore -->
                <BoxView HeightRequest="1" Color="#EEEEEE" Margin="15,0" />

                <!-- Accesso e password -->
