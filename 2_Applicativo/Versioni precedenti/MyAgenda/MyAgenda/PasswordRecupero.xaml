<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyAgenda.PasswordRecupero"
             Title="Recupero Password">

    <ScrollView>
        <VerticalStackLayout Padding="28" Spacing="0" VerticalOptions="Center">

            <VerticalStackLayout Spacing="6" Margin="0,0,0,32">
                <Label Text="🔐" FontSize="44" HorizontalOptions="Center"/>
                <Label Text="Recupero password" Style="{StaticResource TitleLabel}"/>
                <Label Text="Inserisci la tua email per ricevere il link di recupero."
                       Style="{StaticResource SubtitleLabel}"/>
            </VerticalStackLayout>

            <Border Style="{StaticResource CardLarge}">
                <VerticalStackLayout Spacing="18">

                    <Label Text="EMAIL" Style="{StaticResource SectionLabel}"/>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Indirizzo Email" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <Entry x:Name="EmailEntry"
                                   Placeholder="nome@esempio.com"
                                   Keyboard="Email"
                                   ReturnType="Done"/>
                        </Border>
                    </VerticalStackLayout>

                    <Button Text="Invia istruzioni"
                            Style="{StaticResource PrimaryButton}"
                            Clicked="OnSendClicked"/>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
