<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyAgenda.Register"
             BackgroundColor="#F2F2F2"
             Title="Registrati">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="32" VerticalOptions="Center">

            <Label Text="Registrati"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#1A1A1A" />

            <Frame BackgroundColor="White"
                   CornerRadius="32"
                   Padding="32"
                   HasShadow="True">
                <VerticalStackLayout Spacing="16">

                    <!-- Nome Utente -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Nome Utente" FontSize="13" TextColor="#555" />
                        <Frame Padding="0" CornerRadius="8" HasShadow="False"
                               BorderColor="#E0E0E0" HeightRequest="44">
                            <Entry x:Name="UsernameEntry"
                                   Placeholder="Minimo 3 caratteri"
                                   PlaceholderColor="#BDBDBD"
                                   BackgroundColor="Transparent"
                                   Margin="8,0" />
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Password" FontSize="13" TextColor="#555" />
                        <Frame Padding="0" CornerRadius="8" HasShadow="False"
                               BorderColor="#E0E0E0" HeightRequest="44">
                            <Entry x:Name="PasswordEntry"
                                   Placeholder="••••••••"
                                   PlaceholderColor="#BDBDBD"
                                   IsPassword="True"
                                   BackgroundColor="Transparent"
                                   Margin="8,0" />
                        </Frame>

                        <!-- Requisiti password -->
                        <Frame BackgroundColor="#F8F8F8"
                               CornerRadius="8"
                               Padding="12"
                               HasShadow="False"
                               BorderColor="#E0E0E0">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="La password deve contenere:" FontSize="11" TextColor="#888" />
                                <Label Text="✓  Almeno 8 caratteri" FontSize="11" TextColor="#888" />
                                <Label Text="✓  Una lettera maiuscola (A-Z)" FontSize="11" TextColor="#888" />
                                <Label Text="✓  Una lettera minuscola (a-z)" FontSize="11" TextColor="#888" />
                                <Label Text="✓  Un numero (0-9)" FontSize="11" TextColor="#888" />
                                <Label Text="✓  Un carattere speciale (!@#$...)" FontSize="11" TextColor="#888" />
                            </VerticalStackLayout>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Conferma Password -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Conferma Password" FontSize="13" TextColor="#555" />
                        <Frame Padding="0" CornerRadius="8" HasShadow="False"
                               BorderColor="#E0E0E0" HeightRequest="44">
                            <Entry x:Name="ConfirmPasswordEntry"
                                   Placeholder="••••••••"
                                   PlaceholderColor="#BDBDBD"
                                   IsPassword="True"
                                   BackgroundColor="Transparent"
                                   Margin="8,0" />
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Crea account Button -->
                    <Button Text="Crea nuovo account"
                            Clicked="OnCreateAccountClicked"
                            BackgroundColor="#1A1A1A"
                            TextColor="White"
                            CornerRadius="8"
                            HeightRequest="44"
                            Margin="0,8,0,0" />

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
