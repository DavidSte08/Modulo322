<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyAgenda.Attivita"
             BackgroundColor="#ECECEC"
             Title="Attività">

    <Grid ColumnDefinitions="220,*">

        <!-- SINISTRA -->
        <VerticalStackLayout Padding="15"
                             Spacing="15">

            <!-- HOME -->
            <Button Text="←"
                    WidthRequest="40"
                    HeightRequest="40"
                    CornerRadius="20"
                    BackgroundColor="White"
                    HorizontalOptions="Start"
                    Clicked="OnHomeClicked"/>

            

            <!-- DATE PICKER -->
            <Border Stroke="#CCCCCC"
                    BackgroundColor="White"
                    Padding="10">

                <VerticalStackLayout>

                    <DatePicker x:Name="calendarPicker"
                                DateSelected="OnDateSelected"/>

                </VerticalStackLayout>

            </Border>
            <!-- QUICK ADD -->

            <Border Stroke="#CCCCCC"
        BackgroundColor="White"
        Padding="10">

                <VerticalStackLayout Spacing="10">

                    <Label Text="Quick Add"
               FontAttributes="Bold"
               FontSize="18"/>

                    <!-- NOME -->
                    <Picker x:Name="quickNomePicker"
                Title="Nome"/>

                    <!-- TIPO -->
                    <Picker x:Name="quickTipoPicker"
                Title="Tipo"/>

                    <!-- DATA -->
                    <DatePicker x:Name="quickDatePicker"/>

                    <!-- ORA -->
                    <TimePicker x:Name="quickTimePicker"/>

                    <!-- BOTTONE -->
                    <Button Text="Add"
                Clicked="OnQuickAddClicked"/>

                </VerticalStackLayout>

            </Border>
            
            <!-- AGGIUNGI -->
            <Button Text="Crea Nuovo Evento"
                   
        HeightRequest="60"
        BackgroundColor="#00f"
        Clicked="OnAddEventoClicked"/>

        </VerticalStackLayout>

        <!-- CALENDARIO -->
        <!-- CALENDARIO -->
        <Grid Grid.Column="1"
      RowDefinitions="40,*">

            <!-- HEADER FISSO -->
            <ScrollView x:Name="HeaderScroll"
                Grid.Row="0"
                Orientation="Horizontal"
                HorizontalScrollBarVisibility="Never">

                <Grid x:Name="HeaderGrid"
              HeightRequest="40"
              ColumnSpacing="1"
              BackgroundColor="#BBBBBB"/>

            </ScrollView>

            <!-- SCROLL VERTICALE -->
            <ScrollView Grid.Row="1"
                Orientation="Vertical">

                <!-- SCROLL ORIZZONTALE -->
                <ScrollView x:Name="BodyScroll"
                    Orientation="Horizontal"
                    Scrolled="BodyScroll_Scrolled">

                    <Grid x:Name="CalendarioGrid"
                  RowSpacing="1"
                  ColumnSpacing="1"
                  BackgroundColor="#BBBBBB"/>

                </ScrollView>

            </ScrollView>

        </Grid>

    </Grid>

</ContentPage>