<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyAgenda.PasswordRecupero"
             BackgroundColor="#F2F2F2"
             Title="Recupero Password">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="32" VerticalOptions="Center">

            <Label Text="Recupero password"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#1A1A1A" />

            <Frame BackgroundColor="White"
                   CornerRadius="32"
                   Padding="32"
                   HasShadow="True">
                <VerticalStackLayout Spacing="16">

                    <Label Text="Inserisci la tua email per ricevere le istruzioni di recupero."
                           FontSize="13"
                           TextColor="#555" />

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Email" FontSize="13" TextColor="#555" />
                        <Frame Padding="0" CornerRadius="8" HasShadow="False"
                               BorderColor="#E0E0E0" HeightRequest="44">
                            <Entry x:Name="EmailEntry"
                                   Placeholder="nome@esempio.com"
                                   PlaceholderColor="#BDBDBD"
                                   Keyboard="Email"
                                   BackgroundColor="Transparent"
                                   Margin="8,0" />
                        </Frame>
                    </VerticalStackLayout>

                    <Button Text="Invia istruzioni"
                            Clicked="OnSendClicked"
                            BackgroundColor="#1A1A1A"
                            TextColor="White"
                            CornerRadius="8"
                            HeightRequest="44"
                            Margin="0,8,0,0" />

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
