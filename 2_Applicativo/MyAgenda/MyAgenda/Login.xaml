<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyAgenda.Login"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="28" Spacing="0" VerticalOptions="Center">

            <!-- BRAND -->
            <VerticalStackLayout Spacing="6" Margin="0,0,0,36">
                <Label Text="📅" FontSize="48" HorizontalOptions="Center"/>
                <Label Text="MyAgenda"
                       FontSize="28" FontAttributes="Bold"
                       TextColor="#111827"
                       HorizontalOptions="Center"
                       FontFamily="OpenSansSemibold"/>
                <Label Text="La tua agenda scolastica"
                       FontSize="14" TextColor="#6B7280"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- CARD LOGIN -->
            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 28"
                    StrokeThickness="0"
                    Padding="28">
                <VerticalStackLayout Spacing="18">

                    <Label Text="ACCEDI"
                           FontSize="12" FontAttributes="Bold"
                           TextColor="#9CA3AF" CharacterSpacing="1"
                           FontFamily="OpenSansSemibold"/>

                    <!-- Username -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Nome Utente"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="#4B5563"/>
                        <Border BackgroundColor="White"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#E5E7EB" StrokeThickness="1.5"
                                HeightRequest="48" Padding="0">
                            <Entry x:Name="UsernameEntry"
                                   Placeholder="Inserisci username"
                                   PlaceholderColor="#9CA3AF"
                                   BackgroundColor="Transparent"
                                   ReturnType="Next"
                                   Margin="10,0"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Password"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="#4B5563"/>
                        <Border BackgroundColor="White"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#E5E7EB" StrokeThickness="1.5"
                                HeightRequest="48" Padding="0">
                            <Entry x:Name="PasswordEntry"
                                   Placeholder="••••••••"
                                   PlaceholderColor="#9CA3AF"
                                   IsPassword="True"
                                   BackgroundColor="Transparent"
                                   ReturnType="Done"
                                   Margin="10,0"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Bottone accedi -->
                    <Button x:Name="LoginButton"
                            Text="Accedi"
                            BackgroundColor="#2563EB"
                            TextColor="White"
                            FontFamily="OpenSansSemibold"
                            FontSize="15"
                            CornerRadius="12"
                            HeightRequest="50"
                            Margin="0,6,0,0"
                            Clicked="OnLoginClicked"/>

                    <!-- Separatore -->
                    <BoxView HeightRequest="1"
                             BackgroundColor="#E5E7EB"
                             Margin="0,4"/>

                    <!-- Registrazione -->
                    <Button Text="Crea nuovo account"
                            BackgroundColor="Transparent"
                            TextColor="#2563EB"
                            BorderColor="#2563EB"
                            BorderWidth="1.5"
                            FontFamily="OpenSansSemibold"
                            FontSize="15"
                            CornerRadius="12"
                            HeightRequest="50"
                            Clicked="OnRegisterClicked"/>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
