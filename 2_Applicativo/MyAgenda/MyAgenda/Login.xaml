<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyAgenda.Login"
             BackgroundColor="#F2F2F2"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="32" VerticalOptions="Center">

            <Label Text="Accedi"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#1A1A1A" />

            <!-- Card -->
            <Frame BackgroundColor="White"
                   CornerRadius="32"
                   Padding="32"
                   HasShadow="True">
                <VerticalStackLayout Spacing="16">

                    <!-- Nome Utente -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Nome Utente" FontSize="13" TextColor="#555" />
                        <Frame Padding="0" CornerRadius="8" HasShadow="False"
                               BorderColor="#E0E0E0" HeightRequest="44">
                            <Entry x:Name="UsernameEntry"
                                   Placeholder="Nome Utente"
                                   PlaceholderColor="#BDBDBD"
                                   BackgroundColor="Transparent"
                                   Margin="8,0" />
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Password" FontSize="13" TextColor="#555" />
                        <Frame Padding="0" CornerRadius="8" HasShadow="False"
                               BorderColor="#E0E0E0" HeightRequest="44">
                            <Entry x:Name="PasswordEntry"
                                   Placeholder="••••••••"
                                   PlaceholderColor="#BDBDBD"
                                   IsPassword="True"
                                   BackgroundColor="Transparent"
                                   Margin="8,0" />
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Login Button -->
                    <Button Text="Login"
                            Clicked="OnLoginClicked"
                            BackgroundColor="#1A1A1A"
                            TextColor="White"
                            CornerRadius="8"
                            HeightRequest="44"
                            Margin="0,8,0,0" />

                    <!-- Password dimenticata -->
                    <Label Text="Password dimenticata?"
                           HorizontalOptions="Center"
                           FontSize="12"
                           TextColor="#888">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnForgotPasswordTapped" />
                        </Label.GestureRecognizers>
                    </Label>

                    <!-- Crea nuovo account -->
                    <Button Text="Crea nuovo account"
                            Clicked="OnRegisterClicked"
                            BackgroundColor="Transparent"
                            TextColor="#1A1A1A"
                            BorderColor="#1A1A1A"
                            BorderWidth="1"
                            CornerRadius="8"
                            HeightRequest="44" />

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
