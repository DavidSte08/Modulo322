<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Primario — Blu indaco profondo -->
    <Color x:Key="Primary">#2563EB</Color>
    <Color x:Key="PrimaryDark">#1D4ED8</Color>
    <Color x:Key="PrimaryLight">#EEF2FF</Color>

    <!-- Secondario — Viola -->
    <Color x:Key="Secondary">#7C3AED</Color>
    <Color x:Key="SecondaryLight">#F5F3FF</Color>

    <!-- Accento — Verde smeraldo -->
    <Color x:Key="Accent">#059669</Color>
    <Color x:Key="AccentLight">#ECFDF5</Color>

    <!-- Pericolo / Logout -->
    <Color x:Key="Danger">#DC2626</Color>
    <Color x:Key="DangerLight">#FEF2F2</Color>

    <!-- Warning -->
    <Color x:Key="Warning">#D97706</Color>
    <Color x:Key="WarningLight">#FEF3C7</Color>

    <!-- Neutri -->
    <Color x:Key="Gray50">#F9FAFB</Color>
    <Color x:Key="Gray100">#F3F4F6</Color>
    <Color x:Key="Gray200">#E5E7EB</Color>
    <Color x:Key="Gray300">#D1D5DB</Color>
    <Color x:Key="Gray400">#9CA3AF</Color>
    <Color x:Key="Gray500">#6B7280</Color>
    <Color x:Key="Gray600">#4B5563</Color>
    <Color x:Key="Gray700">#374151</Color>
    <Color x:Key="Gray800">#1F2937</Color>
    <Color x:Key="Gray900">#111827</Color>

    <!-- Superfici -->
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceVariant">#F9FAFB</Color>
    <Color x:Key="Background">#F1F5F9</Color>

    <!-- Testo -->
    <Color x:Key="TextPrimary">#111827</Color>
    <Color x:Key="TextSecondary">#6B7280</Color>
    <Color x:Key="TextMuted">#9CA3AF</Color>
    <Color x:Key="TextOnPrimary">#FFFFFF</Color>

    <!-- Bordi -->
    <Color x:Key="BorderLight">#E5E7EB</Color>
    <Color x:Key="BorderMedium">#D1D5DB</Color>

    <!-- Dimensioni font dinamiche (modificate da ThemeService) -->
    <x:Double x:Key="FontSizeBody">14</x:Double>
    <x:Double x:Key="FontSizeLabel">13</x:Double>
    <x:Double x:Key="FontSizeTitle">28</x:Double>
    <x:Double x:Key="FontSizeCard">18</x:Double>

</ResourceDictionary>
