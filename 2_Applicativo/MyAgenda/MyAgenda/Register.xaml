<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyAgenda.Register"
             Title="Registrati">

    <ScrollView>
        <VerticalStackLayout Padding="28" Spacing="0" VerticalOptions="Center">

            <VerticalStackLayout Spacing="6" Margin="0,0,0,32">
                <Label Text="Crea account" Style="{StaticResource TitleLabel}"/>
                <Label Text="Inizia a organizzare la tua agenda"
                       Style="{StaticResource SubtitleLabel}"/>
            </VerticalStackLayout>

            <Border Style="{StaticResource CardLarge}">
                <VerticalStackLayout Spacing="18">

                    <Label Text="DATI ACCOUNT" Style="{StaticResource SectionLabel}"/>

                    <!-- Username -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Nome Utente" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <Entry x:Name="UsernameEntry"
                                   Placeholder="Minimo 3 caratteri"
                                   ReturnType="Next"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Password" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <Entry x:Name="PasswordEntry"
                                   Placeholder="••••••••"
                                   IsPassword="True"
                                   ReturnType="Next"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Conferma password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Conferma Password" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <Entry x:Name="ConfirmPasswordEntry"
                                   Placeholder="••••••••"
                                   IsPassword="True"
                                   ReturnType="Done"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Requisiti password -->
                    <Border BackgroundColor="{StaticResource PrimaryLight}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="0"
                            Padding="14">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Requisiti password"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"/>
                            <Label Text="• Minimo 8 caratteri — Max 64"
                                   FontSize="12" TextColor="{StaticResource Primary}"/>
                            <Label Text="• Una maiuscola e una minuscola"
                                   FontSize="12" TextColor="{StaticResource Primary}"/>
                            <Label Text="• Almeno un numero (0–9)"
                                   FontSize="12" TextColor="{StaticResource Primary}"/>
                            <Label Text="• Un carattere speciale (!@#$...)"
                                   FontSize="12" TextColor="{StaticResource Primary}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Button x:Name="RegisterButton"
                            Text="Crea account"
                            Style="{StaticResource PrimaryButton}"
                            Clicked="OnCreateAccountClicked"/>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
