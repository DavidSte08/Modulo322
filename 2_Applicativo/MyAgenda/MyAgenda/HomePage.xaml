<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyAgenda.HomePage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">

            <Label Text="Benvenuto in MyAgenda!"
                    FontSize="32"
                    HorizontalOptions="Center" />
            
            <Button Text="Vai all'account"
                    Clicked="OnAccountClicked" />
            
            <Button Text="Vai alle attività"
                    Clicked="OnAttivitaClicked" />
            
            <Button Text="Vai alle materie"
                    Clicked="OnMaterieClicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
