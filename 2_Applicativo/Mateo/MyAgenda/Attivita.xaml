<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyAgenda.Attivita"
             BackgroundColor="#ECECEC"
             Title="Attività">

    <Grid ColumnDefinitions="220,*">

        <!-- SINISTRA -->
        <VerticalStackLayout Padding="15"
                             Spacing="15">

            <!-- BACK -->
            <Button Text="←"
                    WidthRequest="40"
                    HeightRequest="40"
                    CornerRadius="20"
                    BackgroundColor="White"
                    HorizontalOptions="Start"
                    Clicked="OnHomeClicked"/>

            <!-- AGGIUNGI -->
            <Button Text="Aggiungi Evento"
                    HeightRequest="40"
                    BackgroundColor="#D9D9D9"
                    Clicked="OnAddEventoClicked"/>

            <!-- CALENDARIO -->
            <Border Stroke="#CCCCCC"
                    BackgroundColor="White"
                    Padding="10">

                <VerticalStackLayout>

                    <DatePicker x:Name="calendarPicker"
                                DateSelected="OnDateSelected"/>

                </VerticalStackLayout>

            </Border>

        </VerticalStackLayout>

        <!-- TABELLA -->
        <ScrollView Grid.Column="1"
                    Orientation="Both">

            <Grid x:Name="CalendarioGrid"
                  Padding="10"
                  RowSpacing="1"
                  ColumnSpacing="1"
                  BackgroundColor="#BBBBBB">

            </Grid>

        </ScrollView>

    </Grid>

</ContentPage>