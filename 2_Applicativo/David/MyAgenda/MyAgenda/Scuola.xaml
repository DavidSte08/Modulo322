<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyAgenda.Scuola"
             Title="Materie">

    <Grid RowDefinitions="Auto,*" Padding="20" RowSpacing="16">

        <!-- ── HEADER ── -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="16">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">

                <!-- Torna indietro -->
                <Button Text="←" Style="{StaticResource IconButton}"
                        BackgroundColor="{StaticResource Gray100}"
                        TextColor="{StaticResource Gray700}"
                        Clicked="OnHomeClicked"/>

                <!-- Semestre attivo -->
                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource PrimaryLight}"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0"
                        Padding="12,8"
                        Margin="12,0"
                        VerticalOptions="Center"
                        HorizontalOptions="Start">
                    <Label x:Name="selectedSemestreLabel"
                           Text="Primo Semestre"
                           FontAttributes="Bold"
                           FontSize="14"
                           TextColor="{StaticResource Primary}"
                           FontFamily="OpenSansSemibold"/>
                </Border>

                <!-- Picker semestre -->
                <Picker Grid.Column="2"
                        x:Name="semestrePicker"
                        Title="Cambia semestre"
                        WidthRequest="180"
                        VerticalOptions="Center"
                        SelectedIndexChanged="OnSemestreSelected">
                    <Picker.Items>
                        <x:String>Primo semestre</x:String>
                        <x:String>Secondo semestre</x:String>
                    </Picker.Items>
                </Picker>

                <!-- Azioni materie -->
                <HorizontalStackLayout Grid.Column="3" Spacing="8" VerticalOptions="Center">
                    <Button Text="＋ Materia"
                            Style="{StaticResource SmallActionButton}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            Clicked="OnAddMateriaClicked"/>
                    <Button Text="✏️ Modifica"
                            Style="{StaticResource SmallActionButton}"
                            Clicked="OnModificaMateriaClicked"/>
                    <Button Text="🗑 Elimina"
                            Style="{StaticResource SmallActionButton}"
                            BackgroundColor="{StaticResource DangerLight}"
                            TextColor="{StaticResource Danger}"
                            Clicked="OnEliminaMateriaClicked"/>
                </HorizontalStackLayout>

            </Grid>
        </Border>

        <!-- ── LISTA MATERIE ── -->
        <CollectionView Grid.Row="1" x:Name="MaterieCollection">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="2"
                                 VerticalItemSpacing="14"
                                 HorizontalItemSpacing="14"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}"
                            Stroke="{StaticResource BorderLight}"
                            StrokeThickness="1"
                            Margin="2">

                        <Grid ColumnDefinitions="*,Auto">

                            <!-- Sinistra: nome + azioni -->
                            <VerticalStackLayout Spacing="12">
                                <Label Text="{Binding Nome}"
                                       Style="{StaticResource CardTitle}"/>

                                <!-- Badge note -->
                                <Label FontSize="12"
                                       TextColor="{StaticResource TextSecondary}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Voti inseriti: "/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <HorizontalStackLayout Spacing="8">
                                    <Button Text="＋"
                                            Style="{StaticResource SmallActionButton}"
                                            BackgroundColor="{StaticResource AccentLight}"
                                            TextColor="{StaticResource Accent}"
                                            Clicked="OnAddNotaClicked"
                                            ToolTipProperties.Text="Aggiungi nota"/>
                                    <Button Text="✏️"
                                            Style="{StaticResource SmallActionButton}"
                                            Clicked="OnModificaNotaClicked"
                                            ToolTipProperties.Text="Modifica nota"/>
                                    <Button Text="🗑"
                                            Style="{StaticResource SmallActionButton}"
                                            BackgroundColor="{StaticResource DangerLight}"
                                            TextColor="{StaticResource Danger}"
                                            Clicked="OnEliminaNotaClicked"
                                            ToolTipProperties.Text="Elimina nota"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <!-- Destra: cerchio media -->
                            <Border Grid.Column="1"
                                    Style="{StaticResource MediaBadge}"
                                    BackgroundColor="{StaticResource PrimaryLight}">
                                <Label Text="{Binding Media}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}"
                                       FontFamily="OpenSansSemibold"/>
                            </Border>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>
